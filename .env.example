# ==========================================
# OmniFlow AI Configuration Environment Setup
# ==========================================

# System General Configurations
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_signing_secret_here
FRONTEND_URL=http://localhost:3000

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://omni_admin:omni_secure_pass123@localhost:5432/omniflow_db?schema=public"

# Redis Caching & Queue Management
REDIS_URL="redis://localhost:6379"

# Vector Database (Pinecone / ChromaDB)
VECTOR_DB_PROVIDER=chroma
VECTOR_DB_URL="http://localhost:8000"
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_ENV=us-west1-gcp
PINECONE_INDEX_NAME=omniflow-kb

# Large Language Models (Gemini / OpenAI / Claude)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here

# Twilio & Telephony Configurations (SMS & AI Voice)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_TWIML_APP_SID=SKXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Voice Services (ElevenLabs & Deepgram)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM # Premium voice ID
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Meta Graph API (WhatsApp Business, Instagram & Facebook Messenger)
META_ACCESS_TOKEN=your_meta_system_user_token_here
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_id_here
META_WEBHOOK_VERIFY_TOKEN=your_custom_webhook_secret_here

# LinkedIn API Integrations
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/v1/auth/linkedin/callback

# Google Calendar & Office integrations
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/integrations/google/callback

# Stripe / Razorpay Subscriptions
STRIPE_SECRET_KEY=sk_test_51P...
STRIPE_WEBHOOK_SECRET=whsec_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
